---
import BaseLayout from "../layouts/BaseLayout.astro";
import { languageRows } from "../facts";
---

<BaseLayout
  title="Languages · Squeezy"
  description="Squeezy supports local code understanding and navigation for 15 programming languages."
  active="languages"
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">language support</span>
      <h1>15 languages for local code understanding.</h1>
      <p class="lead">
        The list below is the supported source-language surface. Support and
        docs pages cover platform targets, providers, and diagnostic commands.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="matrix">
      {
        languageRows.map((row) => (
          <article class="matrix-row">
            <div>
              <h3>{row.name}</h3>
            </div>
            <p>{row.detail}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="section-header wide">
      <span class="eyebrow">fallbacks</span>
      <h2>Unsupported files still remain usable.</h2>
      <p>
        Files outside this list fall back to bounded search, targeted reads,
        shell commands, and verifier tools.
      </p>
      <div class="actions">
        <a class="button" href="/support/" data-track-click="languages_support">Support coverage</a>
        <a class="button" href="/docs/languages/" data-track-click="languages_docs">Language docs</a>
        <a class="button secondary" href="/benchmarks/" data-track-click="languages_benchmarks">Benchmarks</a>
      </div>
    </div>
  </section>
</BaseLayout>
