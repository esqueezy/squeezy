---
import BaseLayout from "../layouts/BaseLayout.astro";
import { providerGroups } from "../facts";
---

<BaseLayout
  title="Providers · Squeezy"
  description="Bring your own model key or local runtime while Squeezy keeps code context focused before the provider call."
  active="providers"
>
  <section class="page-hero">
    <div class="page-hero-inner">
      <span class="eyebrow">providers</span>
      <h1>Bring your model. Keep the waste reduction local.</h1>
      <p class="lead">
        Squeezy works with hosted providers, compatible APIs, and local
        runtimes. The cost work happens before the provider call: focus context,
        shrink repeated output, and track usage.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">model choice</span>
      <h2>Use the route that fits your team.</h2>
      <p>
        Provider setup stays practical: configure credentials or a local
        endpoint, pick a model, and let Squeezy handle the context discipline
        around each turn.
      </p>
    </div>
    <div class="matrix">
      {
        providerGroups.map((row) => (
          <article class="matrix-row">
            <div><h3>{row.name}</h3></div>
            <p>{row.detail}</p>
            {row.status && <span class="status-pill">{row.status}</span>}
          </article>
        ))
      }
    </div>
  </section>

  <section class="section band">
    <div class="grid-3">
      <article class="card">
        <span class="label">routing</span>
        <h3>Simple turns can use cheaper paths</h3>
        <p>Eligible mechanical requests can start on a smaller provider-local model and escalate when the task needs the parent model.</p>
      </article>
      <article class="card">
        <span class="label">accounting</span>
        <h3>Usage is visible where providers expose it</h3>
        <p>Squeezy tracks token usage, cache counters, and estimates when provider metadata makes that possible.</p>
      </article>
      <article class="card">
        <span class="label">control</span>
        <h3>Credentials stay on your machine</h3>
        <p>API keys, OAuth files, cloud credentials, compatible endpoints, and local runtimes are configured locally.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <span class="eyebrow">docs</span>
      <h2>Provider details belong in setup docs.</h2>
      <p>
        Current model IDs, environment variables, pricing metadata, cache
        behavior, and live-test requirements change over time, so the docs keep
        the operational detail.
      </p>
      <div class="actions">
        <a class="button" href="/docs/providers/" data-track-click="providers_docs">Provider docs</a>
        <a class="button secondary" href="/install/" data-track-click="providers_install">Install</a>
      </div>
    </div>
  </section>
</BaseLayout>
