---
const metrics = [
  { label: "Navigation", value: "structure-first" },
  { label: "Context", value: "only what matters" },
  { label: "Reads", value: "targeted slices" },
  { label: "Spend", value: "receipt-tracked" }
];
---

<section class="metric-strip" aria-label="SqueezyAgent operating model">
  {
    metrics.map((metric) => (
      <div>
        <span>{metric.label}</span>
        <strong>{metric.value}</strong>
      </div>
    ))
  }
</section>
